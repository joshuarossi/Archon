  "fields": {
    "summary": "App shell — Vite + React + ConvexProvider + AuthProvider + routing",
    "issuetype": {
      "self": "https://alphapoint.atlassian.net/rest/api/3/issuetype/3",
      "id": "3",
      "description": "A task that needs to be done.",
      "iconUrl": "https://alphapoint.atlassian.net/rest/api/2/universal_avatar/view/type/issuetype/avatar/10318?size=medium",
